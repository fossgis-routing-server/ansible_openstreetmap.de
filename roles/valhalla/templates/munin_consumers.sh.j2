#!/bin/bash
# Managed by ansible — see roles/valhalla/templates/munin_consumers.sh.j2
#
# Request count grouped by client class (the $client_class from nginx, which
# maps the X-Client-Id header against valhalla__client_ids). Same DERIVE-rate
# pattern as munin_count.

LOG="/var/log/nginx/valhalla-api.log"

case "$1" in
    config)
        cat <<'EOF'
graph_title Valhalla requests by client
graph_vlabel requests / ${graph_period}
graph_args --base 1000 --lower-limit 0
graph_category valhalla
graph_period second
EOF
{% for cid in valhalla__client_ids %}
        printf "%s.label %s\n%s.type DERIVE\n%s.min 0\n" \
            "{{ cid | regex_replace('[^a-zA-Z0-9_]', '_') }}" "{{ cid }}" \
            "{{ cid | regex_replace('[^a-zA-Z0-9_]', '_') }}" \
            "{{ cid | regex_replace('[^a-zA-Z0-9_]', '_') }}"
{% endfor %}
        printf "unknown.label unknown\nunknown.type DERIVE\nunknown.min 0\n"
        exit 0
        ;;
esac

awk '
    BEGIN {
{% for cid in valhalla__client_ids %}
        slug["{{ cid }}"] = "{{ cid | regex_replace('[^a-zA-Z0-9_]', '_') }}"
{% endfor %}
    }
    {
        # "client=<class>" is the trailing field of the log_format.
        for (i = NF; i >= 1; i--) {
            if (substr($i, 1, 7) == "client=") {
                cls = substr($i, 8)
                if (cls in slug) counts[slug[cls]]++
                else             counts["unknown"]++
                break
            }
        }
    }
    END {
        for (k in slug) printf "%s.value %d\n", slug[k], counts[slug[k]] + 0
        printf "unknown.value %d\n", counts["unknown"] + 0
    }
' "$LOG"
