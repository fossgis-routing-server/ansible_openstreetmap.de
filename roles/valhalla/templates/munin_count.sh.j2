#!/bin/bash
# Managed by ansible — see roles/valhalla/templates/munin_count.sh.j2
#
# Request count by valhalla endpoint. DERIVE means munin reports the
# rate-per-second between consecutive scrapes; we just emit the
# cumulative total so far.
#
# nginx log format (see nginx-valhalla.conf.j2's valhalla_log):
#   $ip [$time_local] $method $uri $status $bytes rqt=... urt=... client=...
# awk's whitespace split → URI is field 5 ([date and +offset] split into 2).

LOG=/var/log/nginx/valhalla-api.log

case "$1" in
    config)
        cat <<'EOF'
graph_title Valhalla request count
graph_vlabel requests / ${graph_period}
graph_args --base 1000 --lower-limit 0
graph_category valhalla
graph_period second
EOF
        for ep in route isochrone matrix tile status other; do
            printf "%s.label %s\n%s.type DERIVE\n%s.min 0\n" "$ep" "$ep" "$ep" "$ep"
        done
        exit 0
        ;;
esac

awk '
    {
        uri = $5
        if      (uri ~ /^\/route/)                                       route++
        else if (uri ~ /^\/isochrone/)                                   iso++
        else if (uri ~ /^\/(sources_to_targets|optimized_route)/)        matrix++
        else if (uri ~ /^\/tile/)                                        tile++
        else if (uri ~ /^\/status/)                                      status++
        else                                                             other++
    }
    END {
        printf "route.value %d\n",     route  + 0
        printf "isochrone.value %d\n", iso    + 0
        printf "matrix.value %d\n",    matrix + 0
        printf "tile.value %d\n",      tile   + 0
        printf "status.value %d\n",    status + 0
        printf "other.value %d\n",     other  + 0
    }
' "$LOG"
