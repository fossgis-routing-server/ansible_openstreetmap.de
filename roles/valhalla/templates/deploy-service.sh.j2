#!/bin/bash
# Managed by ansible — see roles/valhalla/templates/deploy-service.sh.j2
#
# Pulls valhalla master, rebuilds with service-profile cmake flags, installs,
# and rolling-restarts both per-port valhalla_service instances. Invoked by
# GHA via the valhalla-deploy SSH account (forced command).

set -euo pipefail

LOG_INFO="logger -i -t valhalla-deploy-service -p daemon.info --"

SRCDIR="{{ valhalla__srcdir }}"
read -r -a PORTS <<< "{{ valhalla__service_ports | join(' ') }}"
HEALTH_TIMEOUT_SEC=60

$LOG_INFO "starting deploy-service"

# 1. Pull + rebuild as the valhalla user (owns SRCDIR).
sudo -u "{{ valhalla__user }}" bash <<'EOF'
set -euo pipefail
cd {{ valhalla__srcdir }}

git fetch origin
git checkout -f master
git pull --ff-only
git submodule update --init --recursive

rm -rf build

cmake -S . -B build \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_COMPILER_LAUNCHER=ccache \
    -DCMAKE_CXX_COMPILER_LAUNCHER=ccache \
    -DENABLE_DATA_TOOLS=OFF \
    -DENABLE_SERVICES=ON \
    -DENABLE_HTTP=ON \
    -DENABLE_PYTHON_BINDINGS=OFF \
    -DENABLE_TESTS=OFF \
    -DENABLE_SINGLE_FILES_WERROR=OFF \
    -DVALHALLA_VERSION_MODIFIER=$(git rev-parse --short HEAD)

make -C build -j$(nproc)
EOF

# 2. Install + ldconfig as root.
sudo /usr/bin/make -C "$SRCDIR/build" install
sudo /sbin/ldconfig

# 3. Rolling restart with healthcheck. nginx fails over to the still-up
#    instance via passive health checks while one is mid-restart.
for port in "${PORTS[@]}"; do
    $LOG_INFO "rolling restart valhalla-$port"
    sudo /usr/bin/systemctl restart "valhalla-$port"

    healthy=false
    for i in $(seq 1 $((HEALTH_TIMEOUT_SEC / 2))); do
        if curl -fs "http://127.0.0.1:$port/status" >/dev/null 2>&1; then
            $LOG_INFO "valhalla-$port healthy after ~$((i * 2))s"
            healthy=true
            break
        fi
        sleep 2
    done
    if ! $healthy; then
        $LOG_INFO "valhalla-$port did not become healthy in ${HEALTH_TIMEOUT_SEC}s — aborting"
        exit 1
    fi
done

$LOG_INFO "deploy-service complete"
