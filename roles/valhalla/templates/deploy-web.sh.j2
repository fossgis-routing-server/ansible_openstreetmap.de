#!/bin/bash
# Managed by ansible — see roles/valhalla/templates/deploy-web.sh.j2
#
# Pulls valhalla/web-app master and, if HEAD moved, rebuilds it (vite) and
# rsyncs the result to the nginx webroot. Web-app always tracks master.
#
# Runs entirely as the build user, which owns SRCDIR and the
# webroot. No `sudo -u` elevation, no root.
#
# Invoked from two places:
#   - ansible (this role's web.yml) — once during provisioning,
#     as valhalla__build_user.
#   - SSH from the builder's build-tiles loop — lands as valhalla-deploy
#     directly (the orchestrator key authorizes that account).

set -euo pipefail

LOG_INFO="logger -i -t valhalla-deploy-web -p daemon.info --"

SRCDIR="{{ valhalla__webapp_srcdir }}"
WEBROOT="{{ valhalla__webroot }}"
CLIENT_ID="{{ valhalla__webapp_client_id }}"

$LOG_INFO "deploy-web: starting"

cd "$SRCDIR"

# force-checkout in case of local-tree drift from a previous
# .env.production.local edit; then pull master.
before=$(git rev-parse HEAD)
git fetch origin
git checkout -f master
git pull --ff-only
after=$(git rev-parse HEAD)

if [ "$before" = "$after" ] && [ -f "$WEBROOT/index.html" ]; then
    $LOG_INFO "deploy-web: HEAD unchanged ($after); skipping rebuild"
    exit 0
fi
$LOG_INFO "deploy-web: HEAD moved $before -> $after; rebuilding"

# X-Client-Id baked into the build for request header
echo "VITE_CLIENT_ID=$CLIENT_ID" > .env.production.local

npm ci 2>&1 | $LOG_INFO

npm run build 2>&1 | $LOG_INFO

$LOG_INFO "deploy-web: rsync build/ -> $WEBROOT"
rsync -r --delete build/ "$WEBROOT/"

$LOG_INFO "deploy-web: complete"
