# Managed by ansible — see roles/valhalla/templates/valhalla-deploy-service.sudoers.j2
#
# Sudoers for the valhalla-deploy account on the service host. Allows the
# pull/build/install/restart steps that GHA-driven deploys need; the SSH
# forced-command boundary already restricts what the account can be asked
# to do.
{{ valhalla__deploy_user }} ALL=({{ valhalla__user }}) NOPASSWD: ALL
{{ valhalla__deploy_user }} ALL=(root) NOPASSWD: \
    /usr/bin/make -C {{ valhalla__srcdir }}/build install, \
    /sbin/ldconfig, \
{% for port in valhalla__service_ports %}
    /usr/bin/systemctl restart valhalla-{{ port }}, \
{% endfor %}
    /usr/bin/systemctl reload nginx
