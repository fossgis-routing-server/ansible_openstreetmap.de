{% call server([valhalla__api_hostname], http='forward', https='valhalla-api') %}

    access_log /var/log/nginx/valhalla-api.log valhalla_log;
    error_log  /var/log/nginx/valhalla-api.error.log;

    limit_req_status 429;
    limit_req zone=valhalla_global burst=200 nodelay;

    # CORS: prime_server already stamps `Access-Control-Allow-Origin: *`.
    # OPTIONS is not handled by prime_server
    #
    # The `{ cors_preflight }` marker below tags the duplicated
    # blocks for grep-ability.
{% set cors_preflight %}
        if ($request_method = OPTIONS) {
            add_header 'Access-Control-Allow-Origin'  '*';
            add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS';
            add_header 'Access-Control-Allow-Headers' 'Content-Type, X-Client-Id';
            add_header 'Access-Control-Max-Age'       '86400';
            return 204;
        }
{% endset %}

    # Healthcheck — unrestricted, log-suppressed.
    location = /status {
{{ cors_preflight }}
        access_log off;
        proxy_pass http://valhalla;
        proxy_set_header Host $host;
        proxy_next_upstream error timeout http_502 http_503;
        proxy_connect_timeout 2s;
    }

{% if valhalla__download_in_use | default(False) %}
    # Authenticated tarball downloads. Both files are inode-stable across
    # builds: graph-8000.tar is atomic-mv'd by apply-graph.sh, and
    # graph.tar.zst is cp+mv'd as the last step of apply. In-flight
    # downloads continue from the old inode until their FD closes (ext4
    # POSIX semantics) — see ai/valhalla.md.
    location = /download/tiles.tar {
        auth_basic           "valhalla tile download";
        auth_basic_user_file /etc/nginx/htpasswd/valhalla-download;

        alias                /srv/valhalla/graph-8000.tar;
        default_type         application/x-tar;
        add_header           Content-Disposition 'attachment; filename="valhalla-tiles.tar"';

        access_log /var/log/nginx/valhalla-download.log;
    }

    location = /download/tiles.tar.zst {
        auth_basic           "valhalla tile download";
        auth_basic_user_file /etc/nginx/htpasswd/valhalla-download;

        alias                /srv/valhalla/graph.tar.zst;
        default_type         application/zstd;
        add_header           Content-Disposition 'attachment; filename="valhalla-tiles.tar.zst"';

        access_log /var/log/nginx/valhalla-download.log;
    }
{% endif %}

    # Tile endpoint — vector tiles, higher per-IP rate.
    location /tile {
{{ cors_preflight }}
        limit_req zone=valhalla_tile_per_ip burst=20 delay=10;

        proxy_pass http://valhalla;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_next_upstream error timeout http_502 http_503;
        proxy_connect_timeout 2s;
        proxy_read_timeout    120s;
    }

    # Everything else — routing endpoints with per-IP + global rate limits.
    location / {
{{ cors_preflight }}
        limit_req zone=valhalla_per_ip burst=10 delay=5;

        proxy_pass http://valhalla;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_next_upstream error timeout http_502 http_503;
        proxy_connect_timeout 2s;
        proxy_read_timeout    120s;
    }

{% endcall %}
