#!/bin/bash
# Managed by ansible — see roles/valhalla/templates/build-tiles-loop.sh.j2
#
# Long-lived parent process for the build-tiles systemd unit. ONLY job:
# call build-tiles-iteration.sh in a loop. Each iteration is its own
# child bash process, so bash re-reads build-tiles-iteration.sh from
# disk every iteration — edits to the iteration logic take effect on
# the NEXT iteration automatically, no `systemctl restart` needed.
#
# Manual restart is still needed if you edit THIS wrapper (or the
# systemd unit), but that's rare — the wrapper is intentionally tiny
# and stable.
#
# Failure propagation: `set -e` aborts the wrapper if the iteration
# script exits non-zero, so systemd sees the failure and increments
# its restart counter (Restart=always, StartLimitBurst=3 within 10 min
# pins the unit as `failed` for monitoring).

set -e
while true; do
    "{{ valhalla__basedir }}/scripts/build-tiles-iteration.sh"
done
