{% call server(['newsletter.weeklyosm.eu'], http='forward', https='hugo') %}

    # allow large file uploads (e. g. CSV imports of subscribers)
    client_max_body_size 50M;

    location / {
        proxy_pass http://127.0.0.1:9000;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket-support (Listmonk uses them for Live-Upgrades/Logs in UI)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # security provisions
    location ~ /\.(ht|git) {
        deny all;
    }

    {{ custom_log('newsletter.weeklyosm.eu') }}
{% endcall %}