object Service "Valhalla apply sentinel age" {
    import "generic-service"

    check_command = "file_age"
    host_name = "{{ icinga2_nodename }}"

    vars.file_age_file = "{{ valhalla__apply_sentinel_path }}"
    vars.file_age_warning_time = {{ (valhalla__sentinel_max_age_hours * 3600) | int }}
}
